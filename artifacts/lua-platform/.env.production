# Production environment variables for the frontend
# Set the Express backend URL that the frontend will call
# This should be the URL of your deployed backend server

# Examples:
# VITE_API_URL=https://backend.example.com
# VITE_API_URL=https://api.scriptvault.com

# For now, leave this empty and the frontend will use relative paths (/api)
# You'll need to update this when deploying your backend
VITE_API_URL=
